# Choose one LLM provider: "groq" or "anthropic"
LLM_PROVIDER=groq

# Groq (https://console.groq.com) - fast, free-tier Llama 3.1 inference
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.1-8b-instant

# Anthropic (alternative provider)
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# Embedding model (downloaded once from HuggingFace, then cached locally)
EMBEDDING_MODEL=all-MiniLM-L6-v2

# Storage paths
CHROMA_PERSIST_DIR=./storage/chroma
BM25_INDEX_PATH=./storage/bm25_index.pkl
DOCS_DIR=./data/docs

# Chunking
CHUNK_SIZE=800
CHUNK_OVERLAP=120

# Retrieval
TOP_K_DENSE=8
TOP_K_SPARSE=8
TOP_K_FINAL=4
RRF_K=60
